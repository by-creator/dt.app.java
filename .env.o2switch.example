# O2switch Environment Configuration Template
# Copy this file to /home/dtapp/config/.env.o2switch on your O2switch server
# and update with your actual values

# ============================================
# Database Configuration
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=dtapp
MYSQL_USER=dtapp_user
MYSQL_PASSWORD=StrongPassword123!@#

# ============================================
# Application Configuration
# ============================================
# Port where the application will run (don't expose directly to internet)
PORT=8080

# Your domain name (with https://)
APP_BASE_URL=https://your-domain.com

# Directory for uploaded files (must be writable by application user)
UPLOAD_DIR=/home/dtapp/uploads

# Directory for application logs
LOG_DIR=/home/dtapp/logs

# ============================================
# Database Migration & Initialization
# ============================================
# Enable Flyway database migrations (true on first deployment only)
FLYWAY_ENABLED=true

# Enable data initialization (creates admin user, etc. - true on first deployment only)
DATA_INIT_ENABLED=true

# ============================================
# Email Configuration (SMTP)
# ============================================
# Gmail SMTP Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Generate app-specific password: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=your-app-password

# Custom SMTP (if not using Gmail)
# MAIL_HOST=your-smtp-server.com
# MAIL_PORT=587
# MAIL_USERNAME=your-username
# MAIL_PASSWORD=your-password

# Default recipient emails for notifications
MAIL_TO=sn004-proforma@dakar-terminal.com
MAIL_TO_REMISE=sn004-remise.facturation@dakar-terminal.com

# ============================================
# Security Configuration
# ============================================
# Default admin password (change immediately after first login)
SECURITY_PASSWORD=ChangeThisSecurePassword123!

# ============================================
# JVM Configuration
# ============================================
# Memory settings for Java Virtual Machine
# Adjust based on your server resources
# -Xmx: Maximum heap size
# -Xms: Initial heap size
JAVA_OPTS="-Xmx512m -Xms256m -XX:+UseG1GC"

# ============================================
# Logging Configuration
# ============================================
# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
